# longform.env.example — TEMPLATE da config da esteira (produção / WINDOWS).
# ---------------------------------------------------------------------------
# Como usar (no Windows, a partir da raiz do repo):
#     copy longform\longform.env.example longform\longform.env
# depois edite longform\longform.env se precisar. O atualizar-windows.ps1 já faz
# essa cópia sozinho quando o longform.env ainda não existe.
#
# Precedência (maior vence): ambiente do shell > longform.env > defaults (config.py).
# Linhas KEY=VALUE simples; '#' = comentário. O longform.env real é gitignored
# (NÃO versionado); ESTE .example é o único que vai pro git — mantenha-o genérico
# (sem segredos). Valores aqui são a MELHOR config pra um teste REAL de vídeo no PC.
# ---------------------------------------------------------------------------

# === Etapa 8 — Montagem (a diferença Mac→Windows mora aqui) =================
# 'dynamic' = galeria animada em Remotion/Chromium (movimento + transições ricas:
# flip/clockWipe/glow). É a MELHOR saída e o PC tem GPU + Remotion pra rodar.
# Requer `npm install` em longform\remotion (o atualizar-windows.ps1 garante isso).
# ('ffmpeg' é o caminho leve do Mac, sem Chromium — NÃO use no teste real.)
LONGFORM_RENDER_ENGINE=dynamic

# 'auto' detecta e PROVA o encoder de HW nesta ordem: NVENC (NVIDIA) > QSV (Intel)
# > AMF (AMD) > CPU (libx264). No PC com NVIDIA ele pega NVENC sozinho — rápido.
# Force com 'nvenc' se quiser cravar; 'cpu' só como último recurso (lento).
LONGFORM_FFMPEG_ENCODER=auto

# Legendas single-line (libass, ≤48 chars) queimadas no vídeo. 1=liga, 0=desliga.
LONGFORM_CAPTIONS=1

# Aceleração do render Remotion — defaults já agressivos (descomente só p/ ajustar):
#   LONGFORM_REMOTION_GL=angle             # backend GPU (angle=DirectX no Windows)
#   LONGFORM_REMOTION_HWACCEL=if-possible  # decode por HW quando possível
#   LONGFORM_REMOTION_CONCURRENCY=8        # nº de processos (default = nº de núcleos)

# === Idioma do conteúdo (roteiro + narração + legendas) ====================
# 'en' = saída REAL do canal (produção). 'pt' = MODO TESTE (vídeo em português
# só pra avaliar a história antes de gastar na versão EN). As imagens ficam
# SEMPRE em inglês (direção visual do Magnific), independentemente disto.
LONGFORM_IDIOMA=en

# === Etapa 4 — TTS (narração) ==============================================
# Provider 'capcut' = sidecar em longform\tts\CapCut-TTS (precisa do login CapCut
# no .env dele + `npm run dev`). Alterne p/ 'magnific' (usa créditos do MCP) se
# o sidecar não estiver de pé.
LONGFORM_TTS_PROVIDER=capcut
# Voz primária = Joanne (artista EN feminina). NÃO troque sem pedir.
LONGFORM_TTS_VOICE=XMWzAzwYm487GEok2uG2
# TRAVA DE VOZ: fallback VAZIO = a narração fica SEMPRE na Joanne. Se ela bater
# rate-limit, a Etapa 4 ESPERA e repete a Joanne (não cai pra outra voz). Para
# reativar a troca automática, apague esta linha (o default volta a 'cool_lady,labebe').
LONGFORM_TTS_VOICE_FALLBACK=

# === Etapas 6/7 — Magnific (thumb + imagens) ===============================
# Prefixo do servidor MCP do Magnific conectado no SEU Claude Code. Confirme o
# nome real com `claude mcp list` (config.py assume "mcp__magnific").
LONGFORM_MAGNIFIC_MCP=mcp__magnific
# Modelos já têm defaults curados em config.py (corpo=flux-2-klein, thumb=gpt-2).
# Só descomente p/ trocar:
#   LONGFORM_MAGNIFIC_MODE=flux-2-klein
#   LONGFORM_MAGNIFIC_THUMB_MODE=gpt-2
#   LONGFORM_MAGNIFIC_THUMB_QUALITY=medium

# === Etapa 9 — Publicação (opcional; fora do teste de GERAÇÃO) ==============
# Só relevante quando for publicar no YouTube (publicador.py + AdsPower). Um
# perfil AdsPower por canal — descomente e preencha o user_id de cada canal:
#   LONGFORM_ADSPOWER_SELENA=xxxxxxx
#   LONGFORM_ADSPOWER_MAFIA=xxxxxxx
# Recomprime o final só acima deste tamanho (GB) antes do upload:
#   LONGFORM_COMPRIMIR_LIMIAR_GB=1.5

# === TINAGO_DIR (Whisper / Etapa 4) — NÃO vai aqui =========================
# common.py lê TINAGO_DIR no import (antes deste arquivo). No Windows o DEFAULT já
# é  %USERPROFILE%\TINAGO AUTOMAÇÃO  — se o TINAGO estiver aí, não precisa fazer
# nada. Só se estiver em outro lugar, exporte ANTES de rodar a esteira:
#     setx TINAGO_DIR "D:\caminho\TINAGO AUTOMACAO"   (reabra o terminal depois)
